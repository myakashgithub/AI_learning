    trust_after_30min = manager.get_current_trust('user_123', update=False)
    print(f"\nTrust after 30 min (simulated): {trust_after_30min.score:.2f}")
    
    # Validate action
    validation = manager.validate_action(
        'user_123',
        'financial_medium',
        context={'transaction_value': 500}
    )
    
    print(f"\nAction validation:")
    print(f"  Allowed: {validation['allowed']}")
    print(f"  Current trust: {validation['current_trust']:.2f}")
    print(f"  Required trust: {validation['required_trust']:.2f}")
    print(f"  Requires re-auth: {validation['requires_reauth']}")
    
    # Apply context change penalty
    manager.record_context_change(
        'user_123',
