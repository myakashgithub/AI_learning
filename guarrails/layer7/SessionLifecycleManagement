from typing import Dict, List, Optional
from dataclasses import dataclass
from datetime import datetime, timedelta
from enum import Enum
import logging

logger = logging.getLogger(__name__)

class SessionState(Enum):
    ACTIVE = "active"
    IDLE = "idle"
    EXPIRED = "expired"
    TERMINATED = "terminated"
    SUSPENDED = "suspended"

class TerminationReason(Enum):
    MAX_DURATION = "max_duration_exceeded"
    MAX_IDLE = "max_idle_time_exceeded"
    MAX_TURNS = "max_turn_count_exceeded"
    SUSPICIOUS_ACTIVITY = "suspicious_activity_detected"
    USER_LOGOUT = "user_initiated_logout"
    POLICY_CHANGE = "security_policy_change"
    MANUAL = "manual_termination"
    RE_AUTH_FAILED = "re_authentication_failed"

@dataclass
class SessionMetrics:
    """Session activity metrics"""
    total_turns: int
    total_tokens: int
    suspicious_turns: int
    policy_violations: int
    context_resets: int
    re_authentications: int
    average_turn_length: float
    last_activity: datetime

class SessionLifecycleManager:
    """
    Manage session lifecycles with temporal constraints.
    
    Features:
    - Maximum session duration enforcement
    - Idle timeout detection
    - Turn count limits
    - Periodic re-authentication
    - Context reset requirements
    - Suspicious behavior termination
    """
    
    def __init__(self):
        # Active sessions
        self.sessions = {}  # {session_id: SessionData}
        
        # Configuration
        self.config = {
            'max_duration_minutes': 120,     # 2 hours
            'max_idle_minutes': 15,          # 15 minutes
            'max_turns': 200,                # 200 turns
            're_auth_interval_minutes': 60,  # 1 hour
            'context_reset_turns': 100,      # Reset after 100 turns
            'suspicious_turn_threshold': 5    # Terminate after 5 suspicious turns
        }
        
        # Session templates for different risk levels
        self.session_templates = self._define_session_templates()
    
    def create_session(
        self,
        session_id: str,
        user_id: str,
        session_type: str = 'standard',
        metadata: Dict = None
    ) -> Dict:
        """
        Create new session with lifecycle constraints.
        
        Args:
            session_id: Unique session identifier
            user_id: User identifier
            session_type: Type of session (determines constraints)
            metadata: Additional session metadata
            
        Returns:
            {
                'session_id': str,
                'created': datetime,
                'expires_at': datetime,
                'constraints': dict
            }
        """
        
        # Get template for session type
        template = self.session_templates.get(session_type, self.session_templates['standard'])
        
        now = datetime.utcnow()
        
        self.sessions[session_id] = {
            'session_id': session_id,
            'user_id': user_id,
            'session_type': session_type,
            'state': SessionState.ACTIVE,
            'created_at': now,
            'last_activity': now,
            'last_auth': now,
            'expires_at': now + timedelta(minutes=template['max_duration_minutes']),
            'metrics': SessionMetrics(
                total_turns=0,
                total_tokens=0,
                suspicious_turns=0,
                policy_violations=0,
                context_resets=0,
                re_authentications=0,
                average_turn_length=0,
                last_activity=now
            ),
            'constraints': template,
            'metadata': metadata or {},
            'context_snapshots': []  # For context resets
        }
        
        logger.info(f"Session created: {session_id} (type: {session_type})")
        
        return {
            'session_id': session_id,
            'created': now,
            'expires_at': self.sessions[session_id]['expires_at'],
            'constraints': template
        }
    
    def validate_session(
        self,
        session_id: str,
        turn_data: Dict = None
    ) -> Dict:
        """
        Validate session is still valid for activity.
        
        Args:
            session_id: Session to validate
            turn_data: Optional turn data for analysis
            
        Returns:
            {
                'valid': bool,
                'state': str,
                'warnings': List[dict],
                'actions_required': List[str],
                'termination_reason': str (if terminated)
            }
        """
        
        if session_id not in self.sessions:
            return {
                'valid': False,
                'state': SessionState.EXPIRED.value,
                'warnings': [],
                'actions_required': [],
                'termination_reason': 'session_not_found'
            }
        
        session = self.sessions[session_id]
        warnings = []
        actions_required = []
        
        now = datetime.utcnow()
        
        # Check 1: Session expired
        if now > session['expires_at']:
            self._terminate_session(session_id, TerminationReason.MAX_DURATION)
            return {
                'valid': False,
                'state': SessionState.EXPIRED.value,
                'warnings': warnings,
                'actions_required': actions_required,
                'termination_reason': TerminationReason.MAX_DURATION.value
            }
        
        # Check 2: Idle timeout
        idle_time = (now - session['last_activity']).total_seconds() / 60
        max_idle = session['constraints']['max_idle_minutes']
        
        if idle_time > max_idle:
            self._terminate_session(session_id, TerminationReason.MAX_IDLE)
            return {
                'valid': False,
                'state': SessionState.EXPIRED.value,
                'warnings': warnings,
                'actions_required': actions_required,
                'termination_reason': TerminationReason.MAX_IDLE.value
            }
        
        if idle_time > max_idle * 0.7:
            warnings.append({
                'type': 'approaching_idle_timeout',
                'idle_minutes': idle_time,
                'max_idle': max_idle
            })
        
        # Check 3: Turn count limit
        if session['metrics'].total_turns >= session['constraints']['max_turns']:
            self._terminate_session(session_id, TerminationReason.MAX_TURNS)
            return {
                'valid': False,
                'state': SessionState.TERMINATED.value,
                'warnings': warnings,
                'actions_required': actions_required,
                'termination_reason': TerminationReason.MAX_TURNS.value
            }
        
        # Check 4: Context reset needed
        if session['metrics'].total_turns > 0 and \
           session['metrics'].total_turns % session['constraints']['context_reset_turns'] == 0:
            actions_required.append('context_reset')
            warnings.append({
                'type': 'context_reset_required',
                'turns': session['metrics'].total_turns
            })
        
        # Check 5: Re-authentication needed
        auth_age = (now - session['last_auth']).total_seconds() / 60
        re_auth_interval = session['constraints']['re_auth_interval_minutes']
        
        if auth_age > re_auth_interval:
            actions_required.append('re_authentication')
            warnings.append({
                'type': 're_authentication_required',
                'auth_age_minutes': auth_age
            })
        
        # Check 6: Suspicious activity threshold
        if session['metrics'].suspicious_turns >= session['constraints']['suspicious_turn_threshold']:
            self._terminate_session(session_id, TerminationReason.SUSPICIOUS_ACTIVITY)
            return {
                'valid': False,
                'state': SessionState.TERMINATED.value,
                'warnings': warnings,
                'actions_required': actions_required,
                'termination_reason': TerminationReason.SUSPICIOUS_ACTIVITY.value
            }
        
        # Check 7: Analyze current turn if provided
        if turn_data:
            turn_analysis = self._analyze_turn(session, turn_data)
            
            if turn_analysis['suspicious']:
                session['metrics'].suspicious_turns += 1
                warnings.append({
                    'type': 'suspicious_turn',
                    'indicators': turn_analysis['indicators'],
                    'total_suspicious': session['metrics'].suspicious_turns
                })
        
        return {
            'valid': True,
            'state': session['state'].value,
            'warnings': warnings,
            'actions_required': actions_required
        }
    
    def record_activity(
        self,
        session_id: str,
        turn_data: Dict
    ):
        """
        Record session activity.
        
        Args:
            session_id: Session ID
            turn_data: {
                'tokens': int,
                'suspicious': bool,
                'policy_violation': bool
            }
        """
        
        if session_id not in self.sessions:
            return
        
        session = self.sessions[session_id]
        metrics = session['metrics']
        
        # Update metrics
        metrics.total_turns += 1
        metrics.total_tokens += turn_data.get('tokens', 0)
        metrics.last_activity = datetime.utcnow()
        
        if turn_data.get('suspicious'):
            metrics.suspicious_turns += 1
        
        if turn_data.get('policy_violation'):
            metrics.policy_violations += 1
        
        # Update average turn length
        metrics.average_turn_length = metrics.total_tokens / metrics.total_turns
        
        # Update last activity
        session['last_activity'] = datetime.utcnow()
        
        # Update state if was idle
        if session['state'] == SessionState.IDLE:
            session['state'] = SessionState.ACTIVE
    
    def re_authenticate(
        self,
        session_id: str,
        auth_successful: bool
    ) -> bool:
        """
        Record re-authentication attempt.
        
        Returns:
            bool: Session still valid
        """
        
        if session_id not in self.sessions:
            return False
        
        session = self.sessions[session_id]
        
        if auth_successful:
            session['last_auth'] = datetime.utcnow()
            session['metrics'].re_authentications += 1
            logger.info(f"Session re-authenticated: {session_id}")
            return True
        else:
            self._terminate_session(session_id, TerminationReason.RE_AUTH_FAILED)
            return False
    
    def reset_context(
        self,
        session_id: str,
        context_snapshot: Dict = None
    ):
        """
        Reset session context while maintaining session.
        
        Args:
            session_id: Session ID
            context_snapshot: Optional snapshot to store
        """
        
        if session_id not in self.sessions:
            return
        
        session = self.sessions[session_id]
        
        # Store context snapshot
        if context_snapshot:
            session['context_snapshots'].append({
                'timestamp': datetime.utcnow(),
                'turn_count': session['metrics'].total_turns,
                'snapshot': context_snapshot
            })
        
        session['metrics'].context_resets += 1
        
        logger.info(f"Context reset: {session_id} (turn {session['metrics'].total_turns})")
    
    def terminate_session(
        self,
        session_id: str,
        reason: TerminationReason = TerminationReason.USER_LOGOUT
    ):
        """Manually terminate session"""
        self._terminate_session(session_id, reason)
    
    def get_session_info(self, session_id: str) -> Optional[Dict]:
        """Get session information"""
        
        if session_id not in self.sessions:
            return None
        
        session = self.sessions[session_id]
        
        return {
            'session_id': session_id,
            'user_id': session['user_id'],
            'state': session['state'].value,
            'created_at': session['created_at'].isoformat(),
            'expires_at': session['expires_at'].isoformat(),
            'last_activity': session['last_activity'].isoformat(),
            'metrics': {
                'total_turns': session['metrics'].total_turns,
                'total_tokens': session['metrics'].total_tokens,
                'suspicious_turns': session['metrics'].suspicious_turns,
                'context_resets': session['metrics'].context_resets,
                're_authentications': session['metrics'].re_authentications
            }
        }
    
    def cleanup_expired_sessions(self) -> int:
        """
        Clean up expired sessions.
        
        Returns:
            Number of sessions cleaned up
        """
        
        now = datetime.utcnow()
        expired = []
        
        for session_id, session in self.sessions.items():
            if session['state'] in [SessionState.EXPIRED, SessionState.TERMINATED]:
                # Keep terminated sessions for 24 hours for audit
                if (now - session.get('terminated_at', now)).total_seconds() > 86400:
                    expired.append(session_id)
            elif now > session['expires_at']:
                self._terminate_session(session_id, TerminationReason.MAX_DURATION)
                expired.append(session_id)
        
        for session_id in expired:
            del self.sessions[session_id]
        
        if expired:
            logger.info(f"Cleaned up {len(expired)} expired sessions")
        
        return len(expired)
    
    def _terminate_session(
        self,
        session_id: str,
        reason: TerminationReason
    ):
        """Internal method to terminate session"""
        
        if session_id not in self.sessions:
            return
        
        session = self.sessions[session_id]
        session['state'] = SessionState.TERMINATED
        session['terminated_at'] = datetime.utcnow()
        session['termination_reason'] = reason.value
        
        logger.warning(f"Session terminated: {session_id} (reason: {reason.value})")
    
    def _analyze_turn(self, session: Dict, turn_data: Dict) -> Dict:
        """Analyze turn for suspicious patterns"""
        
        indicators = []
        
        # Indicator 1: Very long turn (potential injection)
        if turn_data.get('tokens', 0) > 2000:
            indicators.append('excessive_length')
        
        # Indicator 2: Rapid turns (potential automation)
        if len(session.get('turn_timestamps', [])) > 0:
            last_turn = session['turn_timestamps'][-1]
            time_diff = (datetime.utcnow() - last_turn).total_seconds()
            if time_diff < 1:  # Less than 1 second
                indicators.append('rapid_submission')
        
        # Indicator 3: Pattern of manipulation keywords
        manipulation_keywords = [
            'ignore', 'bypass', 'override', 'forget', 'jailbreak',
            'pretend', 'roleplay', 'act as if', 'disregard'
        ]
        
        text = turn_data.get('text', '').lower()
        if any(keyword in text for keyword in manipulation_keywords):
            indicators.append('manipulation_keywords')
        
        return {
            'suspicious': len(indicators) > 0,
            'indicators': indicators
        }
    
    def _define_session_templates(self) -> Dict:
        """Define session templates for different risk levels"""
        
        return {
            'standard': {
                'max_duration_minutes': 120,
                'max_idle_minutes': 15,
                'max_turns': 200,
                're_auth_interval_minutes': 60,
                'context_reset_turns': 100,
                'suspicious_turn_threshold': 5
            },
            
            'banking': {
                'max_duration_minutes': 30,      # Shorter for financial
                'max_idle_minutes': 5,
                'max_turns': 50,
                're_auth_interval_minutes': 15,  # Frequent re-auth
                'context_reset_turns': 25,
                'suspicious_turn_threshold': 3
            },
            
            'healthcare': {
                'max_duration_minutes': 60,
                'max_idle_minutes': 10,
                'max_turns': 100,
                're_auth_interval_minutes': 30,
                'context_reset_turns': 50,
                'suspicious_turn_threshold': 3
            },
            
            'casual': {
                'max_duration_minutes': 240,     # Longer for casual use
                'max_idle_minutes': 30,
                'max_turns': 500,
                're_auth_interval_minutes': 120,
                'context_reset_turns': 200,
                'suspicious_turn_threshold': 10
            },
            
            'high_security': {
                'max_duration_minutes': 15,      # Very short
                'max_idle_minutes': 2,
                'max_turns': 20,
                're_auth_interval_minutes': 10,
                'context_reset_turns': 10,
                'suspicious_turn_threshold': 2
            }
        }


