    def _update_system_baseline(self, timestamp: datetime):
        """Update system-wide activity baselines"""
        
        hour = timestamp.hour
        day = timestamp.weekday()
        
        self.system_patterns['hourly_baseline'][hour] += 1
        self.system_patterns['daily_baseline'][day] += 1
        self.system_patterns['last_baseline_update'] = timestamp
    
    def get_user_activity_summary(self, user_id: str) -> Optional[Dict]:
        """Get summary of user's activity pattern"""
        
        if user_id not in self.user_patterns:
            return None
        
        pattern = self.user_patterns[user_id]
        
        # Find most active hour
        most_active_hour = max(
            pattern.hour_distribution,
            key=pattern.hour_distribution.get
        ) if pattern.hour_distribution else None
        
        # Find most active day
        day_names = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']
        most_active_day = max(
            pattern.day_distribution,
            key=pattern.day_distribution.get
        ) if pattern.day_distribution else None
        
        # Calculate average interval
        avg_interval = statistics.mean(pattern.typical_intervals) if pattern.typical_intervals else 0
        
        return {
            'user_id': user_id,
            'total_samples': pattern.total_samples,
            'most_active_hour': most_active_hour,
            'most_active_day': day_names[most_active_day] if most_active_day is not None else None,
            'average_interval_seconds': avg_interval,
            'hour_distribution': dict(pattern.hour_distribution),
            'day_distribution': {
                day_names[k]: v for k, v in pattern.day_distribution.items()
            }
        }


