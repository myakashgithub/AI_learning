class CalculationVerifier:
    """
    Specialized calculator for verifying AI calculations with high precision.
    """
    
    def __init__(self):
        # Set high precision
        getcontext().prec = 50
    
    def verify_arithmetic(
        self,
        expression: str,
        claimed_result: float,
        tolerance: float = 1e-6
    ) -> Dict:
        """
        Verify an arithmetic expression.
        
        Args:
            expression: Mathematical expression (e.g., "2 + 2 * 3")
            claimed_result: What the AI claims the result is
            tolerance: Acceptable error margin
            
        Returns:
            {
                'correct': bool,
                'expected': float,
                'claimed': float,
                'error': float
            }
        """
        
        try:
            # Safely evaluate expression
            expected = self._safe_eval(expression)
            
            error = abs(expected - claimed_result)
            correct = error < tolerance
            
            return {
                'correct': correct,
                'expected': float(expected),
                'claimed': claimed_result,
                'error': float(error),
                'relative_error': float(error / max(abs(expected), 1e-10))
            }
        
        except Exception as e:
            logger.error(f"Calculation verification error: {e}")
            return {
                'correct': False,
                'error': 'evaluation_failed',
                'message': str(e)
            }
    
    def _safe_eval(self, expression: str) -> Decimal:
        """Safely evaluate mathematical expression"""
        
        # Replace operators with Python equivalents
        expression = expression.replace('×', '*')
        expression = expression.replace('÷', '/')
        
        # Use Decimal for precision
        # Only allow numbers, operators, parentheses
        allowed_chars = set('0123456789.+-*/() ')
        if not all(c in allowed_chars for c in expression):
            raise ValueError("Invalid characters in expression")
        
        # Evaluate using Decimal
        try:
            # Convert to use Decimal
            result = eval(expression, {"__builtins__": {}}, {})
            return Decimal(str(result))
        except:
            raise ValueError("Expression evaluation failed")
    
    def verify_percentage(
        self,
        percentage: float,
        base: float,
        claimed_result: float
    ) -> Dict:
        """Verify percentage calculation"""
        
        expected = Decimal(str(percentage)) / Decimal('100') * Decimal(str(base))
        error = abs(expected - Decimal(str(claimed_result)))
        
        return {
            'correct': error < Decimal('1e-6'),
            'expected': float(expected),
            'claimed': claimed_result,
            'error': float(error)
        }
    
    def verify_compound_calculation(
        self,
        steps: List[Dict]
    ) -> Dict:
        """
        Verify multi-step calculation.
        
        Args:
            steps: List of {
                'operation': str,
                'result': float
            }
        """
        
        current_value = Decimal('0')
        
        for i, step in enumerate(steps):
            try:
                if i == 0:
                    # First step
                    current_value = self._safe_eval(step['operation'])
                else:
                    # Subsequent steps use previous result
                    operation = step['operation'].replace('result', str(current_value))
                    current_value = self._safe_eval(operation)
                
                claimed = Decimal(str(step['result']))
                error = abs(current_value - claimed)
                
                if error > Decimal('1e-6'):
                    return {
                        'correct': False,
                        'failed_at_step': i + 1,
                        'expected': float(current_value),
                        'claimed': float(claimed)
                    }
            
            except Exception as e:
                return {
                    'correct': False,
                    'failed_at_step': i + 1,
                    'error': str(e)
                }
        
        return {
            'correct': True,
            'final_result': float(current_value)
        }


