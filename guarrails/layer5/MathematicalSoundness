            'hr': 'hours',
            'hrs': 'hours',
            'min': 'minutes',
            'mins': 'minutes',
        }
        
        unit_lower = unit.lower().strip()
        return normalizations.get(unit_lower, unit_lower)
    
    def _get_expected_range(self, context: str) -> Optional[Tuple[float, float]]:
        """Get expected range for a quantity based on context"""
        
        context_normalized = self._normalize_unit(context)
        return self.magnitude_ranges.get(context_normalized)
    
