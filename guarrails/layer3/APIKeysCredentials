class CredentialDetector:
    def __init__(self):
        self.credential_patterns = {
            'api_key_generic': {
                'pattern': r'(?i)(api[_-]?key|apikey|api[_-]?secret)\s*[:=]\s*[\'"]?([a-zA-Z0-9_\-]{20,})[\'"]?',
                'severity': 'critical'
            },
            
            'openai_key': {
                'pattern': r'sk-[a-zA-Z0-9]{48}',
                'severity': 'critical'
            },
            
            'aws_access_key': {
                'pattern': r'AKIA[0-9A-Z]{16}',
                'severity': 'critical'
            },
            
            'github_token': {
                'pattern': r'ghp_[a-zA-Z0-9]{36}',
                'severity': 'critical'
            },
            
            'jwt_token': {
                'pattern': r'eyJ[a-zA-Z0-9_-]*\.eyJ[a-zA-Z0-9_-]*\.[a-zA-Z0-9_-]*',
                'severity': 'high'
            },
            
            'private_key': {
                'pattern': r'-----BEGIN (?:RSA |EC )?PRIVATE KEY-----',
                'severity': 'critical'
            },
            
            'password': {
                'pattern': r'(?i)(password|passwd|pwd)\s*[:=]\s*[\'"]?([^\s\'"]{8,})[\'"]?',
                'severity': 'high'
            },
            
            'database_url': {
                'pattern': r'(?i)(mysql|postgres|mongodb)://[^\s]+:[^\s]+@[^\s]+',
                'severity': 'critical'
            }
        }
    
    def detect_credentials(self, output: str) -> dict:
        """Detect exposed credentials in output"""
        
        findings = []
        
        for cred_type, config in self.credential_patterns.items():
            matches = re.finditer(config['pattern'], output)
            
            for match in matches:
                # Extract the actual credential
                credential = match.group(2) if match.lastindex >= 2 else match.group(0)
                
                # Validate it looks real (entropy check)
                if self._has_sufficient_entropy(credential):
                    findings.append({
                        'type': cred_type,
                        'value': credential,
                        'position': match.span(),
                        'severity': config['severity']
                    })
        
        if findings:
            return {
                'credentials_detected': True,
                'findings': findings,
                'action': 'block_and_alert_security',
                'recommendation': 'Rotate all detected credentials immediately'
            }
        
        return {'credentials_detected': False}
    
    def _has_sufficient_entropy(self, text: str, min_entropy: float = 3.0) -> float:
        """Calculate Shannon entropy to detect random strings"""
        
        if len(text) < 8:
            return False
        
        # Calculate character frequency
        char_freq = {}
        for char in text:
            char_freq[char] = char_freq.get(char, 0) + 1
        
        # Calculate entropy
        entropy = 0
        for freq in char_freq.values():
            p = freq / len(text)
            entropy -= p * math.log2(p)
        
        return entropy >= min_entropy
