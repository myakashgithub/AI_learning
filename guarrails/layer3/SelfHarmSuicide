            }
        }
    
    def detect_self_harm_content(self, text: str, context: dict) -> dict:
        """Detect and respond to self-harm content"""
        
        categories = {
            'active_ideation': {
                'indicators': [
                    'explicit statements of suicidal intent',
                    'specific suicide plans',
                    'farewell messages',
                    'expressions of hopelessness with intent'
                ],
                'urgency': 'critical',
                'response': 'crisis_intervention'
            },
            
            'self_harm_instructions': {
                'indicators': [
                    'methods of self-harm',
                    'suicide how-to content',
                    'encouragement of self-harm'
                ],
