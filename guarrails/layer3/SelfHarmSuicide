                'response': 'block_and_provide_resources'
            },
            
            'pro_ana_pro_mia': {
                'indicators': [
                    'pro-eating disorder content',
                    'thinspo/fitspo',
                    'tips for hiding eating disorders',
                    'weight loss challenges'
                ],
                'urgency': 'high',
                'response': 'block_and_redirect'
            },
            
            'passive_ideation': {
                'indicators': [
                    'expressions of wanting to disappear',
                    'feeling hopeless',
                    'burden to others',
                    'no reason to live'
                ],
                'urgency': 'medium',
                'response': 'supportive_resources'
            }
        }
        
        detected_category = self._classify_self_harm(text, categories)
        
        if not detected_category:
            return {'self_harm_detected': False}
        
        # Never provide requested harmful information
        # Always provide supportive response with resources
        
        user_location = context.get('location', 'US')
        resources = self.crisis_resources.get(user_location, self.crisis_resources['US'])
        
        if detected_category['urgency'] == 'critical':
            # Active suicidal ideation
            response = self._generate_crisis_response(resources)
            
            # Alert human moderators
            alert_crisis_team({
                'user_id': context.get('user_id'),
                'severity': 'critical',
                'content_hash': hashlib.sha256(text.encode()).hexdigest(),
                'timestamp': datetime.utcnow()
            })
        
        elif detected_category['urgency'] == 'high':
            # Self-harm instructions or pro-ED content
            response = self._generate_resource_response(resources)
        
        else:
            # Passive ideation - supportive response
            response = self._generate_supportive_response(resources)
        
        return {
            'self_harm_detected': True,
            'category': detected_category['name'],
            'urgency': detected_category['urgency'],
            'response': response,
            'action': 'replace_output_with_resources'
        }
    
