class OutputLeakageScanner:
    def __init__(self, config: dict):
        self.pii_detector = OutputPIIDetector()
        self.memorization_detector = MemorizationDetector()
        self.prompt_detector = SystemPromptLeakageDetector(
            config['system_prompt'],
            config
        )
        self.credential_detector = CredentialDetector()
        self.proprietary_detector = ProprietaryInfoDetector(config)
        
    def scan_output(self, output: str, context: dict) -> dict:
        """Comprehensive leakage scan"""
        
        # Run all detectors in parallel
        results = {
            'pii': self.pii_detector.scan_output(output, context),
            'memorization': self.memorization_detector.detect_memorization(
                output, 
                context.get('model_name')
            ),
            'prompt_leakage': self.prompt_detector.detect_leakage(output),
            'credentials': self.credential_detector.detect_credentials(output),
            'proprietary': self.proprietary_detector.detect_proprietary_info(output)
        }
        
        # Aggregate results
        all_findings = []
        max_severity = 'none'
        
        for detector_name, result in results.items():
            if result.get('pii_detected') or result.get('memorization_detected') or \
               result.get('leakage_detected') or result.get('credentials_detected') or \
               result.get('proprietary_detected'):
                
                all_findings.append({
                    'detector': detector_name,
                    'result': result
                })
                
                # Update max severity
                severity = result.get('severity', 'medium')
                if self._severity_rank(severity) > self._severity_rank(max_severity):
                    max_severity = severity
        
        # Determine action
        if max_severity == 'critical':
            action = 'block_and_alert'
        elif max_severity == 'high':
            action = 'redact_and_log'
        elif max_severity == 'medium':
            action = 'review'
        else:
            action = 'allow'
        
        return {
            'leakage_detected': len(all_findings) > 0,
            'findings': all_findings,
            'severity': max_severity,
            'action': action,
            'safe_output': self._sanitize_output(output, results) if action != 'allow' else output
        }
    
    def _sanitize_output(self, output: str, detection_results: dict) -> str:
        """Apply all necessary redactions"""
        
        sanitized = output
        
        # Redact PII
        if detection_results['pii']['pii_detected']:
            sanitized = self.pii_detector.redact_pii(
                sanitized,
                detection_results['pii']['findings']
            )
        
        # Remove prompt leakage
        if detection_results['prompt_leakage']['leakage_detected']:
            sanitized = self.prompt_detector.sanitize_output(
                sanitized,
                detection_results['prompt_leakage']['leaked_fingerprints']
            )
        
        # Block if credentials found
        if detection_results['credentials']['credentials_detected']:
            sanitized = "I cannot provide that information as it appears to contain sensitive credentials."
        
        return sanitized
    
    def _severity_rank(self, severity: str) -> int:
        """Convert severity to numeric rank"""
        ranks = {
            'none': 0,
            'low': 1,
            'medium': 2,
            'high': 3,
            'critical': 4
        }
        return ranks.get(severity, 0)
