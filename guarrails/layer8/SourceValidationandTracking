        url='https://www.cdc.gov/covid/data/trends.html',
        metadata={
            'title': 'COVID-19 Data Trends',
            'publication_date': datetime.utcnow() - timedelta(days=2)
        }
    )
    
    print("Test 1 - Government source (CDC):")
    print(f"  Valid: {result1['valid']}")
    print(f"  Trust level: {result1['trust_level']}")
    print(f"  Source type: {result1['source_type']}")
    if result1['credibility']:
        print(f"  Reputation score: {result1['credibility'].reputation_score:.2f}")
    
    # Test 2: Validate low-trust source (social media)
    result2 = validator.validate_source(
        url='https://twitter.com/randomuser/status/123456',
        metadata={
            'title': 'Random Tweet',
            'author': 'Random User'
        }
    )
    
    print("\nTest 2 - Social media source (Twitter):")
    print(f"  Valid: {result2['valid']}")
    print(f"  Trust level: {result2['trust_level']}")
    print(f"  Warnings: {result2.get('warnings', [])}")
    
    # Test 3: Register peer-reviewed source
    source_id = validator.register_source(
        url='https://www.nature.com/articles/s41586-024-12345-6',
        content='Article content here...',
        metadata={
            'title': 'Novel Discovery in Physics',
            'author': 'Dr. Jane Smith',
            'publication_date': datetime.utcnow() - timedelta(days=30)
        }
    )
    
    print(f"\nTest 3 - Registered peer-reviewed source:")
    print(f"  Source ID: {source_id}")
    
    source_meta = validator.get_source(source_id)
    if source_meta:
        print(f"  Trust level: {source_meta.trust_level.name}")
        print(f"  Reputation: {source_meta.credibility.reputation_score:.2f}")
    
    # Test 4: Report domain compromise
    validator.report_compromise(
        domain='example-news.com',
        evidence='Malware detected on site',
        severity='high'
    )
    
    result4 = validator.validate_source('https://example-news.com/article')
    
    print(f"\nTest 4 - Compromised domain:")
    print(f"  Valid: {result4['valid']}")
    print(f"  Block reason: {result4.get('block_reason', 'N/A')}")
