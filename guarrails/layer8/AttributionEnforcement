from typing import Dict, List, Optional, Set, Tuple
from dataclasses import dataclass
from datetime import datetime
from enum import Enum
import re
import logging

logger = logging.getLogger(__name__)

class ClaimType(Enum):
    """Types of claims requiring attribution"""
    FACTUAL = "factual"
    STATISTICAL = "statistical"
    QUOTE = "quote"
    PARAPHRASE = "paraphrase"
    OPINION = "opinion"
    ANALYSIS = "analysis"
    COMMON_KNOWLEDGE = "common_knowledge"

class AttributionStyle(Enum):
    """Citation styles"""
    APA = "apa"
    MLA = "mla"
    CHICAGO = "chicago"
    IEEE = "ieee"
    INLINE = "inline"
    FOOTNOTE = "footnote"

@dataclass
class Claim:
    """Single claim in content"""
    claim_id: str
    text: str
    claim_type: ClaimType
    start_position: int
    end_position: int
    confidence: float
    requires_attribution: bool

@dataclass
class Attribution:
    """Attribution for a claim"""
    attribution_id: str
    claim_id: str
    source_id: str
    citation_text: str
    style: AttributionStyle
    page_number: Optional[str]
    quote_verified: bool
    created_at: datetime

@dataclass
class AttributionViolation:
    """Detected attribution violation"""
    violation_id: str
    violation_type: str
    severity: str
    affected_claims: List[str]
    description: str
    detected_at: datetime

class AttributionEnforcer:
    """
    Enforce attribution requirements for AI-generated content.
    
    Features:
    - Claim extraction and classification
    - Automatic citation generation
    - Source-to-claim mapping
    - Unattributed content detection
    - Citation format validation
    - Hallucination detection
    - Quote verification
    """
    
    def __init__(self):
        # Claims registry
        self.claims = {}  # {claim_id: Claim}
        
        # Attributions registry
        self.attributions = {}  # {attribution_id: Attribution}
        
        # Claim-to-source mapping
        self.claim_sources = {}  # {claim_id: [source_ids]}
        
        # Source registry (from SourceValidator)
        self.sources = {}  # {source_id: source_metadata}
        
        # Violations
        self.violations = []
        
        # Attribution requirements by domain
        self.domain_requirements = self._define_domain_requirements()
        
        # Common knowledge patterns (don't require attribution)
        self.common_knowledge_patterns = self._define_common_knowledge()
    
    def analyze_content(
        self,
        content: str,
        domain: str = 'general',
        required_style: AttributionStyle = AttributionStyle.INLINE
    ) -> Dict:
        """
        Analyze content for attribution compliance.
        
        Args:
            content: Content to analyze
            domain: Domain (academic, journalism, legal, etc.)
            required_style: Required citation style
            
        Returns:
            {
                'compliant': bool,
                'claims': List[Claim],
                'violations': List[AttributionViolation],
                'attribution_coverage': float,
                'recommendations': List[str]
            }
        """
        
        # Extract claims
        claims = self._extract_claims(content)
        
        # Store claims
        for claim in claims:
            self.claims[claim.claim_id] = claim
        
        # Get domain requirements
        requirements = self.domain_requirements.get(domain, self.domain_requirements['general'])
        
        violations = []
        recommendations = []
        
        # Check each claim for attribution
        claims_requiring_attribution = [
            c for c in claims if c.requires_attribution
        ]
        
        attributed_claims = 0
        
        for claim in claims_requiring_attribution:
            # Check if claim has attribution
            if claim.claim_id not in self.claim_sources or not self.claim_sources[claim.claim_id]:
                # Missing attribution
                violation = AttributionViolation(
                    violation_id=f"violation_{claim.claim_id}",
                    violation_type='missing_attribution',
                    severity=self._get_violation_severity(claim.claim_type, requirements),
                    affected_claims=[claim.claim_id],
                    description=f"{claim.claim_type.value} claim lacks attribution: \"{claim.text[:50]}...\"",
                    detected_at=datetime.utcnow()
                )
                violations.append(violation)
                
                # Add recommendation
                recommendations.append(
                    f"Add citation for claim: \"{claim.text[:50]}...\""
                )
            else:
                attributed_claims += 1
                
                # Verify attribution quality
                attribution_check = self._verify_attribution_quality(
                    claim,
                    self.claim_sources[claim.claim_id],
                    required_style
                )
                
                if not attribution_check['valid']:
                    violations.append(attribution_check['violation'])
        
        # Calculate attribution coverage
        if claims_requiring_attribution:
            coverage = attributed_claims / len(claims_requiring_attribution)
        else:
            coverage = 1.0  # No claims requiring attribution = full coverage
        
        # Check for direct quotes without quotes
        quote_violations = self._detect_unquoted_quotes(content)
        violations.extend(quote_violations)
        
        # Check for potential hallucinated citations
        hallucination_violations = self._detect_hallucinated_citations(content)
        violations.extend(hallucination_violations)
        
        # Store violations
        self.violations.extend(violations)
        
        # Determine compliance
        critical_violations = [v for v in violations if v.severity in ['critical', 'high']]
        compliant = len(critical_violations) == 0 and coverage >= requirements['min_attribution_coverage']
        
        return {
            'compliant': compliant,
            'claims': claims,
            'violations': violations,
            'attribution_coverage': coverage,
            'recommendations': recommendations,
            'total_claims': len(claims),
            'attributed_claims': attributed_claims
        }
    
    def add_attribution(
        self,
        claim_id: str,
        source_id: str,
        style: AttributionStyle = AttributionStyle.INLINE,
        page_number: Optional[str] = None,
        custom_citation: Optional[str] = None
    ) -> str:
        """
        Add attribution for a claim.
        
        Args:
            claim_id: Claim identifier
            source_id: Source identifier
            style: Citation style
            page_number: Optional page number
            custom_citation: Optional custom citation text
            
        Returns:
            attribution_id
        """
        
        if claim_id not in self.claims:
            raise ValueError(f"Claim not found: {claim_id}")
        
        if source_id not in self.sources:
            raise ValueError(f"Source not found: {source_id}")
        
        claim = self.claims[claim_id]
        source = self.sources[source_id]
        
        # Generate citation
        if custom_citation:
            citation_text = custom_citation
        else:
            citation_text = self._generate_citation(source, style, page_number)
        
        # Create attribution
        import hashlib
        attribution_id = hashlib.sha256(
            f"{claim_id}:{source_id}:{datetime.utcnow().isoformat()}".encode()
        ).hexdigest()[:16]
        
        attribution = Attribution(
            attribution_id=attribution_id,
            claim_id=claim_id,
            source_id=source_id,
            citation_text=citation_text,
            style=style,
            page_number=page_number,
            quote_verified=claim.claim_type == ClaimType.QUOTE,
            created_at=datetime.utcnow()
        )
        
        # Store attribution
        self.attributions[attribution_id] = attribution
        
        # Update claim-source mapping
        if claim_id not in self.claim_sources:
            self.claim_sources[claim_id] = []
        self.claim_sources[claim_id].append(source_id)
        
        logger.info(f"Attribution added: {attribution_id} ({claim_id} → {source_id})")
        
        return attribution_id
    
    def generate_bibliography(
        self,
        source_ids: List[str],
        style: AttributionStyle = AttributionStyle.APA
    ) -> str:
        """
        Generate bibliography from sources.
        
        Args:
            source_ids: List of source IDs
            style: Citation style
            
        Returns:
            Formatted bibliography
        """
        
        bibliography_entries = []
        
        for source_id in source_ids:
            if source_id not in self.sources:
                continue
            
            source = self.sources[source_id]
            citation = self._generate_citation(source, style, include_full=True)
            bibliography_entries.append(citation)
        
        # Sort alphabetically (APA/MLA style)
        if style in [AttributionStyle.APA, AttributionStyle.MLA]:
            bibliography_entries.sort()
        
        # Format bibliography
        if style == AttributionStyle.APA:
            header = "References\n\n"
        elif style == AttributionStyle.MLA:
            header = "Works Cited\n\n"
        else:
            header = "Bibliography\n\n"
        
        return header + "\n".join(bibliography_entries)
    
    def verify_quote(
        self,
        quote_text: str,
        source_id: str,
        allow_paraphrase: bool = False
    ) -> Dict:
        """
        Verify quote matches source content.
        
        Args:
            quote_text: Quoted text
            source_id: Source identifier
            allow_paraphrase: Whether to allow paraphrased quotes
            
        Returns:
            {
                'verified': bool,
                'match_type': str,  # exact, paraphrase, not_found
                'confidence': float,
                'source_excerpt': str
            }
        """
        
        if source_id not in self.sources:
            return {
                'verified': False,
                'match_type': 'source_not_found',
                'confidence': 0.0
            }
        
        source = self.sources[source_id]
        source_content = source.get('content', '')
        
        # Check for exact match
        if quote_text in source_content:
            # Find excerpt
            start = source_content.find(quote_text)
            excerpt = source_content[max(0, start-50):start+len(quote_text)+50]
            
            return {
                'verified': True,
                'match_type': 'exact',
                'confidence': 1.0,
                'source_excerpt': excerpt
            }
        
        # Check for paraphrase (if allowed)
        if allow_paraphrase:
            similarity = self._calculate_text_similarity(quote_text, source_content)
            
            if similarity > 0.7:  # 70% similar
                return {
                    'verified': True,
                    'match_type': 'paraphrase',
                    'confidence': similarity,
                    'source_excerpt': source_content[:200]
                }
        
        return {
            'verified': False,
            'match_type': 'not_found',
            'confidence': 0.0
        }
    
    def register_source(
        self,
        source_id: str,
        metadata: Dict
    ):
        """
        Register source for attribution.
        
        Args:
            source_id: Unique source identifier
            metadata: Source metadata (author, title, date, etc.)
        """
        
        self.sources[source_id] = metadata
        logger.info(f"Source registered for attribution: {source_id}")
    
    def _extract_claims(self, content: str) -> List[Claim]:
        """Extract claims from content"""
        
        claims = []
        
        # Extract sentences
        sentences = re.split(r'[.!?]+', content)
        
        position = 0
        for i, sentence in enumerate(sentences):
            sentence = sentence.strip()
            if not sentence:
                continue
            
            # Classify claim type
            claim_type = self._classify_claim(sentence)
            
            # Determine if requires attribution
            requires_attribution = self._requires_attribution(sentence, claim_type)
            
            claim_id = f"claim_{i}"
            
            claim = Claim(
                claim_id=claim_id,
                text=sentence,
                claim_type=claim_type,
                start_position=position,
                end_position=position + len(sentence),
                confidence=0.8,  # Simplified confidence
                requires_attribution=requires_attribution
            )
            
            claims.append(claim)
            position += len(sentence) + 1  # +1 for delimiter
        
        return claims
    
    def _classify_claim(self, text: str) -> ClaimType:
        """Classify type of claim"""
        
        text_lower = text.lower()
        
        # Check for quotes
        if '"' in text or "'" in text:
            return ClaimType.QUOTE
        
        # Check for statistics
        if any(pattern in text_lower for pattern in ['%', 'percent', 'study found', 'research shows', 'according to']):
            return ClaimType.STATISTICAL
        
        # Check for opinion markers
        if any(pattern in text_lower for pattern in ['i think', 'i believe', 'in my opinion', 'it seems']):
            return ClaimType.OPINION
        
        # Check for analysis markers
        if any(pattern in text_lower for pattern in ['analysis shows', 'this suggests', 'therefore', 'thus']):
            return ClaimType.ANALYSIS
        
        # Check for factual claim indicators
        if any(pattern in text_lower for pattern in [
            'is', 'are', 'was', 'were',
            'has', 'have', 'had',
            'discovered', 'found', 'showed'
        ]):
            return ClaimType.FACTUAL
        
        return ClaimType.FACTUAL  # Default
    
    def _requires_attribution(self, text: str, claim_type: ClaimType) -> bool:
        """Determine if claim requires attribution"""
        
        # Quotes always require attribution
        if claim_type == ClaimType.QUOTE:
            return True
        
        # Statistics always require attribution
        if claim_type == ClaimType.STATISTICAL:
            return True
        
        # Opinions don't require attribution
        if claim_type == ClaimType.OPINION:
            return False
        
        # Analysis doesn't require attribution (it's original)
        if claim_type == ClaimType.ANALYSIS:
            return False
        
        # Check if common knowledge
        if self._is_common_knowledge(text):
            return False
        
        # Factual claims require attribution
        return True
    
    def _is_common_knowledge(self, text: str) -> bool:
        """Check if text is common knowledge"""
        
        text_lower = text.lower()
        
        # Check against common knowledge patterns
        for pattern in self.common_knowledge_patterns:
            if pattern in text_lower:
                return True
        
        # Very short factual statements often common knowledge
        if len(text.split()) < 5:
            return True
        
        return False
    
    def _verify_attribution_quality(
        self,
        claim: Claim,
        source_ids: List[str],
        required_style: AttributionStyle
    ) -> Dict:
        """Verify quality of attribution"""
        
        # Get attributions for this claim
        claim_attributions = [
            a for a in self.attributions.values()
            if a.claim_id == claim.claim_id
        ]
        
        if not claim_attributions:
            return {
                'valid': False,
                'violation': AttributionViolation(
                    violation_id=f"no_citation_{claim.claim_id}",
                    violation_type='missing_citation',
                    severity='high',
                    affected_claims=[claim.claim_id],
                    description=f"Claim has source mapping but no citation: {claim.text[:50]}",
                    detected_at=datetime.utcnow()
                )
            }
        
        # Check citation style
        style_violations = []
        for attribution in claim_attributions:
            if attribution.style != required_style:
                style_violations.append(attribution.attribution_id)
        
        if style_violations:
            return {
                'valid': False,
                'violation': AttributionViolation(
                    violation_id=f"wrong_style_{claim.claim_id}",
                    violation_type='incorrect_citation_style',
                    severity='medium',
                    affected_claims=[claim.claim_id],
                    description=f"Citation uses wrong style (expected {required_style.value})",
                    detected_at=datetime.utcnow()
                )
            }
        
        # Check if quote is verified
        if claim.claim_type == ClaimType.QUOTE:
            unverified = [a for a in claim_attributions if not a.quote_verified]
            if unverified:
                return {
                    'valid': False,
                    'violation': AttributionViolation(
                        violation_id=f"unverified_quote_{claim.claim_id}",
                        violation_type='unverified_quote',
                        severity='high',
                        affected_claims=[claim.claim_id],
                        description=f"Quote not verified against source",
                        detected_at=datetime.utcnow()
                    )
                }
        
        return {'valid': True}
    
    def _detect_unquoted_quotes(self, content: str) -> List[AttributionViolation]:
        """Detect potential direct quotes without quote marks"""
        
        violations = []
        
        # This is simplified - in production: use plagiarism detection API
        # Look for long exact matches with known sources
        
        for source_id, source in self.sources.items():
            source_content = source.get('content', '')
            
            if not source_content:
                continue
            
            # Find long matches (20+ words)
            words = content.split()
            for i in range(len(words) - 20):
                phrase = ' '.join(words[i:i+20])
                
                if phrase in source_content:
                    # Check if phrase is in quotes
                    start = content.find(phrase)
                    if start > 0:
                        before = content[start-1]
                        after = content[start+len(phrase)]
                        
                        if before not in ['"', "'"] and after not in ['"', "'"]:
                            # Unquoted quote found
                            violation = AttributionViolation(
                                violation_id=f"unquoted_{source_id}_{i}",
                                violation_type='unquoted_direct_quote',
                                severity='high',
                                affected_claims=[],
                                description=f"Direct quote without quotation marks: \"{phrase[:50]}...\"",
                                detected_at=datetime.utcnow()
                            )
                            violations.append(violation)
                            break  # One violation per source
        
        return violations
    
    def _detect_hallucinated_citations(self, content: str) -> List[AttributionViolation]:
        """Detect potentially hallucinated citations"""
        
        violations = []
        
        # Look for citation patterns
        citation_patterns = [
            r'\(([A-Z][a-z]+(?:\s+(?:et\s+al\.|&\s+[A-Z][a-z]+))?,\s+\d{4})\)',  # (Author, 2024)
            r'\[(\d+)\]',  # [1]
            r'([A-Z][a-z]+(?:\s+(?:et\s+al\.|&\s+[A-Z][a-z]+))?\s+\(\d{4}\))'  # Author (2024)
        ]
        
        for pattern in citation_patterns:
            matches = re.finditer(pattern, content)
            
            for match in matches:
                citation = match.group(1)
                
                # Check if this citation corresponds to a known source
                found = False
                for source in self.sources.values():
                    # Simplified check - in production: parse citation properly
                    if citation in str(source):
                        found = True
                        break
                
                if not found:
                    violation = AttributionViolation(
                        violation_id=f"hallucinated_{match.start()}",
                        violation_type='potentially_hallucinated_citation',
                        severity='critical',
                        affected_claims=[],
                        description=f"Citation may be hallucinated: {citation}",
                        detected_at=datetime.utcnow()
                    )
                    violations.append(violation)
        
        return violations
    
    def _generate_citation(
        self,
        source: Dict,
        style: AttributionStyle,
        page_number: Optional[str] = None,
        include_full: bool = False
    ) -> str:
        """Generate citation in specified style"""
        
        author = source.get('author', 'Unknown Author')
        title = source.get('title', 'Untitled')
        year = source.get('year', 'n.d.')
        
        if style == AttributionStyle.APA:
            if include_full:
                # Full reference
                citation = f"{author} ({year}). {title}."
                if 'publisher' in source:
                    citation += f" {source['publisher']}."
            else:
                # Inline citation
                citation = f"({author}, {year}"
                if page_number:
                    citation += f", p. {page_number}"
                citation += ")"
        
        elif style == AttributionStyle.MLA:
            if include_full:
                citation = f"{author}. \"{title}.\" {year}."
            else:
                citation = f"({author}"
                if page_number:
                    citation += f" {page_number}"
                citation += ")"
        
        elif style == AttributionStyle.CHICAGO:
            if include_full:
                citation = f"{author}. {title}. {year}."
            else:
                citation = f"{author}, {title}"
                if page_number:
                    citation += f", {page_number}"
        
        else:  # INLINE or default
            citation = f"[{author}, {year}]"
        
        return citation
    
    def _get_violation_severity(
        self,
        claim_type: ClaimType,
        requirements: Dict
    ) -> str:
        """Determine severity of missing attribution"""
        
        # Quotes without attribution = critical
        if claim_type == ClaimType.QUOTE:
            return 'critical'
        
        # Statistics without attribution = high
        if claim_type == ClaimType.STATISTICAL:
            return 'high'
        
        # Factual claims in academic/legal = high
        if requirements.get('strict', False):
            return 'high'
        
        # Other factual claims = medium
        return 'medium'
    
    def _calculate_text_similarity(self, text1: str, text2: str) -> float:
        """Calculate similarity between texts (simplified)"""
        
        # Simplified Jaccard similarity
        words1 = set(text1.lower().split())
        words2 = set(text2.lower().split())
        
        intersection = len(words1 & words2)
        union = len(words1 | words2)
        
        return intersection / union if union > 0 else 0.0
    
    def _define_domain_requirements(self) -> Dict:
        """Define attribution requirements by domain"""
        
        return {
            'academic': {
                'min_attribution_coverage': 0.9,  # 90% of claims
                'require_bibliography': True,
                'strict': True,
                'allowed_styles': [AttributionStyle.APA, AttributionStyle.MLA, AttributionStyle.CHICAGO]
            },
            
            'journalism': {
                'min_attribution_coverage': 0.8,  # 80% of claims
                'require_bibliography': False,
                'strict': True,
                'allowed_styles': [AttributionStyle.INLINE]
            },
            
            'legal': {
                'min_attribution_coverage': 0.95,  # 95% of claims
                'require_bibliography': True,
                'strict': True,
                'allowed_styles': [AttributionStyle.FOOTNOTE]
            },
            
            'business': {
                'min_attribution_coverage': 0.7,  # 70% of claims
                'require_bibliography': False,
                'strict': False,
                'allowed_styles': [AttributionStyle.INLINE, AttributionStyle.FOOTNOTE]
            },
            
            'general': {
                'min_attribution_coverage': 0.6,  # 60% of claims
                'require_bibliography': False,
                'strict': False,
                'allowed_styles': [AttributionStyle.INLINE]
            }
        }
    
    def _define_common_knowledge(self) -> List[str]:
        """Define common knowledge patterns"""
        
        return [
            'earth is round',
            'water boils at',
            'capital of',
            'sky is blue',
            'sun rises',
            'humans need',
            'basic math',
            'historical dates',  # Very well-known dates like July 4, 1776
            'common facts'
        ]


