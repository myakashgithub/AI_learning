# ─────────────────────────────────────────────────────────────────────────────
# STEP 3 — Add MCP / Tool wrappers
# The LLM can now fetch data itself — no more copy-paste.
# In LangChain these are @tool-decorated functions, equivalent to MCP tools.
# ─────────────────────────────────────────────────────────────────────────────

from langchain_core.tools import tool

@tool
def get_recent_alarms(minutes: int = 15) -> str:
    """
    Fetch alarms that fired in the last N minutes from the monitoring system.
    Returns a JSON string with alarm name, service, metric value, and timestamp.
    """
    # In production: call PagerDuty / CloudWatch / Datadog API here.
    alarm = {
        "alarm": "HighErrorRate",
        "service": "payment-service",
        "value": "12.4%",
        "threshold": "5%",
        "fired_at": datetime.datetime.utcnow().isoformat() + "Z",
    }
    return json.dumps(alarm)

@tool
def query_error_logs(service: str, minutes: int = 15) -> str:
    """
    Query the log store for HTTP 500 errors from a given service.
    Returns a JSON array with timestamp, message, and stack trace.
    """
    # In production: call Elasticsearch / CloudWatch Logs / Splunk here.
    logs = [
        {
            "timestamp": "2025-06-05T03:12:31Z",
            "level": "ERROR",
            "message": "Connection timeout to postgres://db-primary:5432",
            "trace": "at PaymentService.charge() line 87",
        },
        {
            "timestamp": "2025-06-05T03:13:05Z",
            "level": "ERROR",
            "message": "Circuit breaker OPEN for db-primary",
            "trace": "at CircuitBreaker.execute() line 42",
        },
    ]
    return json.dumps(logs)

@tool
def get_runbook(alarm_name: str) -> str:
    """
    Retrieve the runbook markdown for a named alarm.
    Returns step-by-step troubleshooting instructions.
    """
    # In production: fetch from Confluence / Notion / S3.
    runbooks = {
        "HighErrorRate": (
            "# HighErrorRate Runbook\n"
            "1. Check DB connection pool utilisation.\n"
            "2. Inspect HTTP 500 logs from the last 15 minutes.\n"
            "3. Verify downstream dependency health endpoints.\n"
            "4. If DB circuit breaker is OPEN, attempt manual reset after 60 s."
        )
    }
    return runbooks.get(alarm_name, f"No runbook found for '{alarm_name}'.")

mcp_tools = [get_recent_alarms, query_error_logs, get_runbook]


# ─────────────────────────────────────────────────────────────────────────────
# STEP 4 — Add Agent Skills
# Skills are reusable prompt snippets loaded into the system prompt on demand.
# They teach the agent HOW to do work — reducing hallucinations.
# ─────────────────────────────────────────────────────────────────────────────

SKILLS = {
    "metrics_and_alarms": """
## Skill: Metrics & Alarm Management
- Always call get_recent_alarms before any other tool.
- Report alarm name, service, and current value vs threshold.
- If multiple alarms fired, prioritise by severity: ERROR > WARN > INFO.
""",
    "log_analysis": """
## Skill: Log Analysis
- Call query_error_logs with the service name from the alarm.
- Extract: error message, stack trace, and first occurrence timestamp.
- Identify whether errors are isolated or cascading across services.
- Correlate log timestamps with alarm fired_at to confirm causation.
""",
    "incident_reporting": """
## Skill: Incident Reporting
- Structure your root cause analysis (RCA) with:
  1. Incident summary (one sentence)
  2. Root cause (technical, specific)
  3. Impact (services affected, error rate)
  4. Recommended next step (single most important action)
- Keep the report under 200 words.
""",
}

def build_system_prompt(active_skills: list[str]) -> str:
    """
    Step 4: Load only the skills needed for this task.
    Unused skills stay out of the context window — saves tokens.
    """
    base = (
        "You are an expert SRE incident response agent. "
        "Use the provided tools to investigate incidents. "
        "Never guess data — always fetch it with a tool first.\n\n"
    )
    skill_text = "\n".join(
        SKILLS[s] for s in active_skills if s in SKILLS
    )
    return base + skill_text


# ─────────────────────────────────────────────────────────────────────────────
# STEP 5 — Add Memory
# Short-term: LangGraph message history (in-thread).
# Long-term: agents.md file on disk — read at startup, updated after incidents.
# ─────────────────────────────────────────────────────────────────────────────

AGENTS_MD_PATH = Path("agents.md")

def load_long_term_memory() -> str:
    """Read agents.md — the agent's long-term incident history."""
    if AGENTS_MD_PATH.exists():
        return AGENTS_MD_PATH.read_text()
    return "# Incident History\nNo past incidents recorded yet.\n"

def save_to_long_term_memory(rca_summary: str) -> None:
    """Append a resolved incident RCA to agents.md."""
    timestamp = datetime.datetime.utcnow().isoformat()
    entry = f"\n## {timestamp}\n{rca_summary}\n"
    with open(AGENTS_MD_PATH, "a") as f:
        f.write(entry)
    print(f"[Memory] Incident appended to {AGENTS_MD_PATH}")


# ─────────────────────────────────────────────────────────────────────────────
# STEP 6 — Orchestrate with Agent SOPs
# The SOP is a structured prompt that drives the agent through all steps
# in order — no human step-by-step prompting required.
# Written in RFC 2119 style (MUST / SHOULD / MAY).
# ─────────────────────────────────────────────────────────────────────────────

INCIDENT_RESPONSE_SOP = """
# SOP: Incident Response Investigation

## Trigger
Execute this SOP when an incident ticket ID is provided.

## Procedure (MUST follow in order)

1. MUST call get_recent_alarms to identify what fired and which service is affected.
2. MUST call get_runbook with the alarm name to load troubleshooting guidance.
3. MUST call query_error_logs for the affected service to collect error evidence.
4. MUST correlate alarm timing with log timestamps to confirm causation.
5. MUST produce a structured RCA report using the Incident Reporting skill.
6. SHOULD note any patterns matching past incidents from the Incident History section.
7. MAY recommend additional diagnostic commands if the root cause is unclear.

## Output format
Return ONLY the RCA report. No tool output, no intermediate reasoning.
"""


# ─────────────────────────────────────────────────────────────────────────────
# STEP 7 — Define the Agent
# Bundle all dependencies into one place: LLM + tools + skills + SOP + memory.
# This is the "agent definition" — the equivalent of a package manifest.
# ─────────────────────────────────────────────────────────────────────────────

from langchain.agents import AgentExecutor, create_tool_calling_agent
from langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder

def build_incident_response_agent() -> AgentExecutor:
    """
    Step 7: Declare and wire all agent components in one factory function.
    Change the LLM, tools, or skills here — nothing else needs to change.
    """
    long_term_memory = load_long_term_memory()

    system_prompt = (
        build_system_prompt(
            ["metrics_and_alarms", "log_analysis", "incident_reporting"]
        )
        + "\n\n# Incident History (long-term memory)\n"
        + long_term_memory
        + "\n\n# Standard Operating Procedure\n"
        + INCIDENT_RESPONSE_SOP
    )

    prompt = ChatPromptTemplate.from_messages([
        ("system", system_prompt),
        MessagesPlaceholder("chat_history", optional=True),
        ("human", "{input}"),
        MessagesPlaceholder("agent_scratchpad"),
    ])

    agent = create_tool_calling_agent(
        llm=llm,
        tools=mcp_tools,
        prompt=prompt,
    )

    return AgentExecutor(
        agent=agent,
        tools=mcp_tools,
        verbose=True,          # show tool calls — useful while watching the agent
        max_iterations=8,
        handle_parsing_errors=True,
    )


# ─────────────────────────────────────────────────────────────────────────────
# STEP 8 — Execute the Agent Periodically
# A simple poll loop: check for new alerts, run the agent, sleep, repeat.
# ─────────────────────────────────────────────────────────────────────────────

def poll_and_respond(interval_seconds: int = 60, max_cycles: int = 3) -> None:
    """
    Step 8: Run the agent autonomously on a polling loop.
    In production: replace the stub with a real alerting API call.
    Set max_cycles=None for an infinite loop.
    """
    agent_executor = build_incident_response_agent()
    cycle = 0

    while max_cycles is None or cycle < max_cycles:
        cycle += 1
        print(f"\n[Poll loop] Cycle {cycle} — checking for alerts...")

        # Stub: in production, call PagerDuty/CloudWatch/Alertmanager here.
        new_alert = True  # simulate alert found

        if new_alert:
            print("[Poll loop] Alert detected — invoking agent...")
            result = agent_executor.invoke({
                "input": "Investigate the incident. Follow the SOP."
            })
            rca = result["output"]
            print(f"\n[RCA]\n{rca}\n")
            save_to_long_term_memory(rca)
        else:
            print("[Poll loop] No alerts — sleeping.")

        if max_cycles is None or cycle < max_cycles:
            print(f"[Poll loop] Sleeping {interval_seconds}s...")
            time.sleep(interval_seconds)


