# STEP 2 — Start using an LLM
# Replace manual analysis with an LLM call. Human still moves data around.
# ─────────────────────────────────────────────────────────────────────────────

from langchain_openai import ChatOpenAI
from langchain_core.messages import HumanMessage, SystemMessage

llm = ChatOpenAI(model="gpt-4o-mini", temperature=0)

def llm_analyse_logs(logs: list[dict]) -> str:
    """
    Step 2: paste data to the LLM; get analysis back.
    Human still fetches logs manually and copy-pastes them here.
    """
    logs_text = json.dumps(logs, indent=2)
    messages = [
        SystemMessage(content=(
            "You are an expert SRE. Analyse the provided logs and identify "
            "the root cause concisely."
        )),
        HumanMessage(content=f"Review these logs and tell me what is failing:\n{logs_text}"),
    ]
    response = llm.invoke(messages)
    return response.content

