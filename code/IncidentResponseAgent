# ─────────────────────────────────────────────────────────────────────────────
# STEP 10 — Scale to Multiple Agents
# Orchestrator receives the trigger and fans out to specialist subagents.
# Subagents share results via the filesystem (agents.md) — no message bus needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Specialist subagents ──────────────────────────────────────────────────────

def build_log_analyst_agent() -> AgentExecutor:
    """Subagent: focused only on log analysis."""
    prompt = ChatPromptTemplate.from_messages([
        ("system", (
            "You are a log analysis specialist. "
            "Your ONLY job: call query_error_logs, extract the root error, "
            "and return a single-paragraph technical summary. No fluff."
            + build_system_prompt(["log_analysis"])
        )),
        ("human", "{input}"),
        MessagesPlaceholder("agent_scratchpad"),
    ])
    agent = create_tool_calling_agent(llm=llm, tools=[query_error_logs], prompt=prompt)
    return AgentExecutor(agent=agent, tools=[query_error_logs], verbose=False, max_iterations=4)

def build_infra_check_agent() -> AgentExecutor:
    """Subagent: focused only on alarm triage + runbook lookup."""
    prompt = ChatPromptTemplate.from_messages([
        ("system", (
            "You are an infrastructure triage specialist. "
            "Call get_recent_alarms and get_runbook, then return a one-paragraph "
            "summary of what fired and what the runbook says to do."
            + build_system_prompt(["metrics_and_alarms"])
        )),
        ("human", "{input}"),
        MessagesPlaceholder("agent_scratchpad"),
    ])
    agent = create_tool_calling_agent(
        llm=llm, tools=[get_recent_alarms, get_runbook], prompt=prompt
    )
    return AgentExecutor(
        agent=agent, tools=[get_recent_alarms, get_runbook], verbose=False, max_iterations=4
    )

# ── Filesystem message bus ────────────────────────────────────────────────────

WORKSPACE = Path("workspace")
WORKSPACE.mkdir(exist_ok=True)

def write_subagent_output(agent_name: str, content: str) -> None:
    path = WORKSPACE / f"{agent_name}_output.md"
    path.write_text(content)
    print(f"[Filesystem] {agent_name} wrote output to {path}")

def read_all_subagent_outputs() -> str:
    outputs = []
    for f in sorted(WORKSPACE.glob("*_output.md")):
        outputs.append(f"### {f.stem}\n{f.read_text()}")
    return "\n\n".join(outputs)

# ── Orchestrator ──────────────────────────────────────────────────────────────

def orchestrator(ticket_id: str) -> str:
    """
    Step 10: Orchestrator fans out to specialist subagents, collects their
    filesystem outputs, then synthesises a final RCA.
    """
    print(f"\n[Orchestrator] Starting multi-agent investigation for {ticket_id}")

    # 1. Run infra triage subagent
    infra_agent = build_infra_check_agent()
    infra_result = infra_agent.invoke({"input": f"Triage the incident for ticket {ticket_id}."})
    write_subagent_output("infra_check", infra_result["output"])

    # 2. Run log analyst subagent
    log_agent = build_log_analyst_agent()
    log_result = log_agent.invoke({"input": f"Analyse error logs for ticket {ticket_id}."})
    write_subagent_output("log_analyst", log_result["output"])

    # 3. Orchestrator reads all outputs and synthesises the final RCA
    combined = read_all_subagent_outputs()
    long_term = load_long_term_memory()

    synthesis_prompt = [
        SystemMessage(content=(
            "You are an incident response orchestrator. "
            "You have received reports from specialist subagents. "
            "Synthesise them into a single structured RCA following this format:\n"
            "1. Incident summary\n2. Root cause\n3. Impact\n4. Recommended action\n\n"
            f"# Past incidents (long-term memory)\n{long_term}"
        )),
        HumanMessage(content=f"Subagent reports:\n\n{combined}"),
    ]
    final_rca = llm.invoke(synthesis_prompt).content
    save_to_long_term_memory(final_rca)

    print(f"\n[Orchestrator] Final RCA:\n{final_rca}")
    return final_rca


